# Server
PORT=5000
NODE_ENV=development

# MongoDB Atlas connection string
# Example: mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/policyflow?retryWrites=true&w=majority
MONGODB_URI=mongodb://mongo
# Session secret (use a long random string in production)
SESSION_SECRET=change-this-to-a-secure-random-string

# Frontend URL for CORS (comma-separated for multiple origins)
CLIENT_URL=http://localhost:5173

# Default admin credentials (used by seed script only)
ADMIN_EMAIL=admin@policyflow.com
ADMIN_PASSWORD=Admin@123
